{
  "expo": {
    "name": "SignGuard AI",
    "slug": "signguard-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "signguardai",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050508"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.signguard.ai",
      "buildNumber": "3",
      "infoPlist": {
        "NSCameraUsageDescription": "SignGuard AI uses your camera to scan and analyze contract documents.",
        "NSPhotoLibraryUsageDescription": "SignGuard AI accesses your photo library so you can upload contract images for analysis.",
        "NSPhotoLibraryAddUsageDescription": "SignGuard AI saves your contract scan results to your photo library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.signguard.ai",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#050508"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "SignGuard AI uses your camera to scan and analyze contract documents."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SignGuard AI accesses your photo library so you can upload contract images for analysis.",
          "cameraPermission": "SignGuard AI uses your camera to scan contract documents."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "signguard",
          "project": "signguard-ai"
        }
      ],
      "@sentry/react-native",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "6694883c-fee6-48b8-909b-016310f8faf3"
      },
      "router": {}
    },
    "owner": "edmirth",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/6694883c-fee6-48b8-909b-016310f8faf3"
    }
  }
}
